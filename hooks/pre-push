#!/usr/bin/env bash
# pre-push hook — Engineering Governance Framework
#
# Bloquea el push si hay archivos de código modificados en el último commit
# sin que ningún archivo de docs-system haya sido actualizado también.
#
# Instalar:
#   cp .governance/hooks/pre-push .git/hooks/pre-push
#   chmod +x .git/hooks/pre-push
#
# O usar install.sh --hooks

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

DOCS_DIR="docs-system"

# Archivos que no cuentan como "código" (no activan el chequeo)
IGNORE_PATTERNS=(
  "^\.git/"
  "^\.github/"
  "^\.cursor/"
  "^\.agent/"
  "^docs-system/"
  "^\.clinerules"
  "^\.windsurfrules"
  "^CLAUDE\.md"
  "^AGENTS\.md"
  "^README\.md"
  "^\.env"
  "node_modules/"
  "\.lock$"
  "\.json$"
)

# Archivos que se consideran "código" (activan el chequeo)
CODE_PATTERNS=(
  "\.ts$"
  "\.js$"
  "\.py$"
  "\.go$"
  "\.java$"
  "\.rb$"
  "\.php$"
  "\.rs$"
  "\.cs$"
  "\.yml$"
  "\.yaml$"
  "\.tf$"
  "\.sql$"
)

# ─── Obtener archivos del último commit ──────────────────────────────────────

CHANGED_FILES=$(git diff --name-only HEAD~1 HEAD 2>/dev/null || git diff --name-only --cached)

if [[ -z "$CHANGED_FILES" ]]; then
  exit 0
fi

# ─── Clasificar archivos ─────────────────────────────────────────────────────

has_code_changes=false
has_docs_changes=false

while IFS= read -r file; do
  # ¿Es un archivo de docs-system?
  if [[ "$file" == ${DOCS_DIR}/* ]]; then
    has_docs_changes=true
    continue
  fi

  # ¿Está en la lista de ignorados?
  ignored=false
  for pattern in "${IGNORE_PATTERNS[@]}"; do
    if echo "$file" | grep -qE "$pattern"; then
      ignored=true
      break
    fi
  done
  [[ "$ignored" == "true" ]] && continue

  # ¿Es código?
  for pattern in "${CODE_PATTERNS[@]}"; do
    if echo "$file" | grep -qE "$pattern"; then
      has_code_changes=true
      break
    fi
  done
done <<< "$CHANGED_FILES"

# ─── Evaluar ─────────────────────────────────────────────────────────────────

if [[ "$has_code_changes" == "true" && "$has_docs_changes" == "false" ]]; then
  echo ""
  echo -e "${RED}[governance] Push bloqueado — docs-system no actualizado${NC}"
  echo ""
  echo "  Se detectaron cambios de código sin actualización en /docs-system."
  echo ""
  echo "  Archivos de código modificados:"
  while IFS= read -r file; do
    ignored=false
    for pattern in "${IGNORE_PATTERNS[@]}"; do
      if echo "$file" | grep -qE "$pattern"; then ignored=true; break; fi
    done
    [[ "$ignored" == "true" ]] && continue
    for pattern in "${CODE_PATTERNS[@]}"; do
      if echo "$file" | grep -qE "$pattern"; then
        echo "    - $file"
        break
      fi
    done
  done <<< "$CHANGED_FILES"
  echo ""
  echo "  Qué actualizar según el tipo de cambio:"
  echo "    Nueva funcionalidad    → PRODUCT_SURFACE.md + USER_FLOW_MATRIX.md"
  echo "    Cambio de integración  → INTEGRATIONS.md"
  echo "    Cambio de arquitectura → ARCHITECTURE.md + DIAGRAMS.md"
  echo "    Bug fix / deuda        → TECHNICAL_DEBT_ROADMAP.md"
  echo "    Gap resuelto           → GAPS.md"
  echo ""
  echo "  Si el cambio realmente no requiere actualizar docs (ej: refactor interno):"
  echo ""
  echo -e "  ${YELLOW}git push -o skip-governance-check${NC}"
  echo ""
  exit 1
fi

if [[ "$has_code_changes" == "true" && "$has_docs_changes" == "true" ]]; then
  echo -e "${GREEN}[governance] docs-system actualizado — push permitido${NC}"
fi

exit 0
